@startwbs
skinparam dpi 200
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam shadowing false
skinparam ArrowColor #1A3A6A
skinparam wbsDiagram {
  BorderColor #1A3A6A
}

<style>
wbsDiagram {
  Linecolor #1A3A6A
  arrow {
    Linecolor #1A3A6A
    Linethickness 1.4
  }
  :depth(0) {
    BackgroundColor #1A3A6A
    FontColor #FFFFFF
    BorderColor #1A3A6A
    FontStyle bold
    FontSize 13
    Padding 8
    RoundCorner 8
  }
  :depth(1) {
    BackgroundColor #3A5A8A
    FontColor #FFFFFF
    BorderColor #1A3A6A
    FontStyle bold
    RoundCorner 6
    Padding 6
  }
  :depth(2) {
    BackgroundColor #E8F0FA
    FontColor #1A3A6A
    BorderColor #3A5A8A
    Padding 5
    RoundCorner 4
  }
  :depth(3) {
    BackgroundColor #FFEBD1
    FontColor #6B3A0F
    BorderColor #E65100
    Padding 4
    RoundCorner 3
  }
}
</style>

