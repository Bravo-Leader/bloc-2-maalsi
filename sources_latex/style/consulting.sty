% Constat / Key finding (bleu clair)
\newtcolorbox{finding}[1][]{
  enhanced,
  colback=cnLightBlue,
  colframe=cnNavy,
  leftrule=4pt, rightrule=0pt, toprule=0pt, bottomrule=0pt,
  arc=0pt,
  fonttitle=\bfseries\small\color{cnNavy},
  title={\ding{118}\enspace Constat clé},
  coltitle=cnNavy,
  attach boxed title to top left={yshift=-2mm, xshift=4pt},
  boxed title style={colback=white, colframe=white},
  boxsep=4pt, top=6pt, bottom=4pt, left=6pt, right=6pt,
  before skip=6pt, after skip=6pt,
  #1
}

