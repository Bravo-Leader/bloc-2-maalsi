% ── En-têtes et pieds de page ───────────────────────────────
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[L]{%
  \begin{tikzpicture}[remember picture, overlay]
    \draw[cnNavy, line width=0.5pt] (0,0) -- (\textwidth,0);
  \end{tikzpicture}%
  \vspace{2pt}\small\textcolor{cnSlate}{BricoLoc 2.0 \textbf{·} Architecture Logicielle du SI}%
}
\fancyhead[R]{\small\textcolor{cnSlate}{\thepage}}
\fancyfoot[C]{\tiny\textcolor{cnSlate}{Document confidentiel — V. Coudert — CESI MAALSI 2026}}
\renewcommand{\footrulewidth}{0pt}

% Style de la page de chapitre (pas de header)
\fancypagestyle{chapterpage}{
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \fancyfoot[C]{\tiny\textcolor{cnSlate}{Document confidentiel — V. Coudert — CESI MAALSI 2026}}
}

% ── Chapitres ────────────────────────────────────────────────
% Chapter opener : pleine largeur, fond navy, texte blanc
\titleformat{\chapter}[block]
  {\normalfont}
  {}
  {0pt}
  {\chapterTitleBox}
  []

\newcommand{\chapterTitleBox}[1]{%
  \thispagestyle{chapterpage}%
  \begin{tikzpicture}
    \node[fill=cnNavy, text width=\textwidth, inner xsep=1cm, inner ysep=1.2cm,
          align=left, text=white] {%
      \normalfont\scriptsize\textcolor{cnOrange}{\MakeUppercase{Partie \thechapter}}\\[6pt]
      \normalfont\LARGE\bfseries #1%
    };
  \end{tikzpicture}%
  \vspace{0.6cm}%
}
\titlespacing*{\chapter}{0pt}{0pt}{0pt}

% ── Sections ─────────────────────────────────────────────────
\titleformat{\section}
  {\normalfont\large\bfseries\color{cnNavy}}
  {\color{cnOrange}\rule[-3pt]{4pt}{14pt}\hspace{8pt}\thesection}
  {0.4em}
  {}
  []
\titlespacing*{\section}{0pt}{10pt}{4pt}

\titleformat{\subsection}
  {\normalfont\normalsize\bfseries\color{cnNavy}}
  {\thesubsection}
  {0.5em}
  {}
  []
\titlespacing*{\subsection}{0pt}{6pt}{2pt}

% ── Colonnes tabularx ────────────────────────────────────────
\newcolumntype{L}[1]{>{\raggedright\arraybackslash}p{#1}}
\newcolumntype{C}[1]{>{\centering\arraybackslash}p{#1}}
\newcolumntype{R}[1]{>{\raggedleft\arraybackslash}p{#1}}
\newcolumntype{Y}{>{\RaggedRight\arraybackslash}X}

% ── Helper cellule d'en-tête de tableau ──────────────────────
\providecommand{\th}[1]{\textcolor{white}{\textbf{#1}}}
\renewcommand{\th}[1]{\textcolor{white}{\textbf{#1}}}

% ── Espacement figures / tableaux ────────────────────────────
\setlength{\parskip}{2pt}
\setlength{\floatsep}{4pt}
\setlength{\textfloatsep}{6pt}
\setlength{\intextsep}{4pt}
\setlength{\abovecaptionskip}{3pt}
\setlength{\belowcaptionskip}{2pt}
\captionsetup{font=small, labelfont={bf,color=cnNavy}, textfont=it}

